UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then draggingSlider = false end end)
UserInputService.InputChanged:Connect(function(input)
	if draggingSlider and input.UserInputType == Enum.UserInputType.MouseMovement then
		local percent = math.clamp((UserInputService:GetMouseLocation().X - sliderBar.AbsolutePosition.X) / sliderBar.AbsoluteSize.X, 0, 1)
		sliderDot.Position = UDim2.new(percent, -7, 0.5, -7)
		fuerzaMagneto = percent * 0.5
		strengthLabel.Text = string.format("FUERZA AIM: %.2f", fuerzaMagneto)
	end
end)

-- --- LOGICA SHIFT LOCK ---
local function toggleShiftLock()
	shiftLockEnabled = not shiftLockEnabled
	shiftLockBtn.Text = shiftLockEnabled and "SHIFT LOCK [0]: ON" or "SHIFT LOCK [0]: OFF"
	shiftLockBtn.BackgroundColor3 = shiftLockEnabled and Color3.fromRGB(0, 140, 255) or Color3.fromRGB(25, 25, 25)
	
	if not shiftLockEnabled then
		UserInputService.MouseBehavior = Enum.MouseBehavior.Default
	end
end
shiftLockBtn.MouseButton1Click:Connect(toggleShiftLock)

UserInputService.InputBegan:Connect(function(i, g)
	if not g and (i.KeyCode == Enum.KeyCode.Zero or i.KeyCode == Enum.KeyCode.KeypadZero) then toggleShiftLock() end
	if not g and i.UserInputType == Enum.UserInputType.MouseButton2 then aimActive = true end
end)
UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton2 then aimActive = false end end)

-- --- BUCLE DE RENDERIZADO ---
RunService.RenderStepped:Connect(function()
	if shiftLockEnabled then
		UserInputService.MouseBehavior = Enum.MouseBehavior.LockCenter
	end

	-- Skeletons/X-Ray
	if skeletonsEnabled then
		local rainbow = Color3.fromHSV(tick() % 5 / 5, 1, 1)
		for _, p in pairs(Players:GetPlayers()) do
			if p ~= LocalPlayer and p.Character then
				local hi = p.Character:FindFirstChild("AuraHighlight") or Instance.new("Highlight", p.Character)
				hi.Name = "AuraHighlight"
				hi.FillColor = rainbow
				hi.OutlineColor = rainbow
				hi.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
			end
		end
	end

	-- Hitbox Expander (TORSO EXPANDIDO)
	for _, p in pairs(Players:GetPlayers()) do
		if p ~= LocalPlayer and p.Character then
			local torso = p.Character:FindFirstChild("UpperTorso") or p.Character:FindFirstChild("Torso")
			if torso then
				if hitboxEnabled then
					torso.Size = Vector3.new(hitboxSize, hitboxSize, hitboxSize)
					torso.Transparency = 0.6
					torso.Color = Color3.fromRGB(0, 170, 255) -- Color Aura Company
					torso.CanCollide = false
				else
					torso.Size = (p.Character:FindFirstChild("UpperTorso")) and Vector3.new(1.6, 1.6, 1) or Vector3.new(2, 2, 1)
					torso.Transparency = 0
				end
			end
		end
	end

	-- Aim Assist
	if aimActive then
		local target = nil
		local shortestDist = radioDeteccion
		for _, p in pairs(Players:GetPlayers()) do
			if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then
				local part = p.Character:FindFirstChild(parteObjetivo)
				if part then
					local pos, onScreen = Camera:WorldToViewportPoint(part.Position)
					if onScreen then
						local dist = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
						if dist < shortestDist then target = part shortestDist = dist end
					end
				end
			end
		end
		if target then Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, target.Position), fuerzaMagneto) end
	end
end)

skeletonBtn.MouseButton1Click:Connect(function()
	skeletonsEnabled = not skeletonsEnabled
	skeletonBtn.Text = skeletonsEnabled and "SKELETONS: ON" or "SKELETONS: OFF"
	skeletonBtn.BackgroundColor3 = skeletonsEnabled and Color3.fromRGB(0, 200, 100) or Color3.fromRGB(25, 25, 25)
	if not skeletonsEnabled then
		for _, p in pairs(Players:GetPlayers()) do
			if p.Character and p.Character:FindFirstChild("AuraHighlight") then p.Character.AuraHighlight:Destroy() end
		end
	end
end)

hitboxBtn.MouseButton1Click:Connect(function()
	hitboxEnabled = not hitboxEnabled
	hitboxBtn.Text = hitboxEnabled and "HITBOX EXPANDER: ON" or "HITBOX EXPANDER: OFF"
	hitboxBtn.BackgroundColor3 = hitboxEnabled and Color3.fromRGB(0, 170, 255) or Color3.fromRGB(25, 25, 25)
end)

-- Draggable
local dFrame, dStart, sPos
mainFrame.InputBegan:Connect(function(i) 
	if i.UserInputType == Enum.UserInputType.MouseButton1 and not draggingSlider then 
		dFrame = true dStart = i.Position sPos = mainFrame.Position 
	end 
end)
UserInputService.InputChanged:Connect(function(i) 
	if dFrame and i.UserInputType == Enum.UserInputType.MouseMovement then
		local delta = i.Position - dStart
		mainFrame.Position = UDim2.new(sPos.X.Scale, sPos.X.Offset + delta.X, sPos.Y.Scale, sPos.Y.Offset + delta.Y)
	end 
end)
UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dFrame = false end end)
