-- --- FUNCION WALL CHECK ---
local function isVisible(part)
    local castPoints = {Camera.CFrame.Position, part.Position}
    local ignoreList = {LocalPlayer.Character, part.Parent}
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.FilterDescendantsInstances = ignoreList
    
    local ray = workspace:Raycast(castPoints[1], castPoints[2] - castPoints[1], params)
    if ray and ray.Instance then
        return false
    end
    return true
end

-- --- BUCLE DE RENDERIZADO ---
RunService.RenderStepped:Connect(function()
    if shiftLockEnabled then UserInputService.MouseBehavior = Enum.MouseBehavior.LockCenter end
    if fullBrightEnabled then Lighting.Brightness = 2; Lighting.ClockTime = 14; Lighting.FogEnd = 100000; Lighting.GlobalShadows = false end

    -- Logica Visual Esqueletos
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local hi = p.Character:FindFirstChild("AuraHighlight")
            if skeletonsEnabled and not streamerMode then
                if not hi then hi = Instance.new("Highlight", p.Character); hi.Name = "AuraHighlight" end
                hi.Enabled = true
                hi.FillColor = Color3.fromHSV(tick() % 5 / 5, 1, 1); hi.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            else
                if hi then hi.Enabled = false end
            end
        end
    end

    -- --- LOGICA HITBOX (CORREGIDA PARA MODO STREAMER) ---
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local torso = p.Character:FindFirstChild("UpperTorso") or p.Character:FindFirstChild("Torso")
            if torso and p.Character:FindFirstChild("Humanoid") then
                if streamerMode then
                    -- Si el modo streamer esta ON, restauramos apariencia visual pero mantenemos el hit si esta ON (opcional)
                    -- En este caso, forzamos invisibilidad y tamaño normal para que no se note NADA.
                    if torso.Size.X > 2.1 or torso.Transparency ~= 0 then
                        torso.Size = (p.Character:FindFirstChild("UpperTorso")) and Vector3.new(1.6, 1.6, 1) or Vector3.new(2, 2, 1)
                        torso.Transparency = 0
                    end
                elseif hitboxEnabled then
                    -- Modo Normal: Hitbox Activo
                    torso.Size = Vector3.new(hitboxSize, hitboxSize, hitboxSize)
                    torso.Transparency = hitboxTransparency
                    torso.Color = Color3.fromRGB(0, 170, 255)
                    torso.CanCollide = false
                    torso.Massless = true
                else
                    -- Modo Normal: Hitbox Apagado
                    if torso.Size.X > 2.1 then 
                        torso.Size = (p.Character:FindFirstChild("UpperTorso")) and Vector3.new(1.6, 1.6, 1) or Vector3.new(2, 2, 1)
                        torso.Transparency = 0 
                        torso.Massless = false 
                    end
                end
            end
        end
    end

    if noRecoilEnabled or rapidFireEnabled then
        for _, v in pairs(LocalPlayer.Character:GetDescendants()) do
            if v:IsA("NumberValue") then
                if noRecoilEnabled and v.Name:find("Recoil") then v.Value = 0 end
                if rapidFireEnabled and (v.Name:find("Delay") or v.Name:find("Cooldown")) then v.Value = 0 end
            end
        end
    end

    -- Logica Aimbot
    if aimActive and aimbotEnabled then
        local target = nil; local shortestDist = radioDeteccion
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then
                local part = p.Character:FindFirstChild(parteObjetivo)
                if part then
                    if wallCheckEnabled and not isVisible(part) then continue end
                    
                    local pos, onScreen = Camera:WorldToViewportPoint(part.Position)
                    if onScreen then
                        local dist = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                        if dist < shortestDist then target = {Part = part, ScreenPos = pos} shortestDist = dist end
                    end
                end
            end
        end
        if target then 
            if aimMode == "CAMARA" then Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, target.Part.Position), fuerzaMagneto) 
            else
                local mousePos = UserInputService:GetMouseLocation()
                local moveVector = (Vector2.new(target.ScreenPos.X, target.ScreenPos.Y) - mousePos) * fuerzaMagneto
                if mousemoverel then mousemoverel(moveVector.X, moveVector.Y) end
            end
        end
    end
end)

