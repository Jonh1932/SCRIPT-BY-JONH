UserInputService.InputBegan:Connect(function(i, g)
    if g then return end
    
    -- MODO STREAMER (TECLA L)
    if i.KeyCode == Enum.KeyCode.L then
        streamerMode = not streamerMode
        mainFrame.Visible = not streamerMode
    end

    if isBinding and i.UserInputType == Enum.UserInputType.Keyboard then
        aimbotBind = i.KeyCode; bindBtn.Text = "BIND: " .. i.KeyCode.Name; isBinding = false; return
    end
    if i.KeyCode == aimbotBind and aimbotEnabled then
        aimActive = not aimActive; aimbotBtn.Text = aimActive and "AIMBOT: ACTIVE" or "AIMBOT: ON"
        aimbotBtn.BackgroundColor3 = aimActive and Color3.fromRGB(255, 50, 50) or Color3.fromRGB(0, 170, 255)
    end
end)

